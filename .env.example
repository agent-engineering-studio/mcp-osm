# ── Ollama ───────────────────────────────────────────────────────────────────
# Default: Ollama is running on the host (Windows/macOS).
# For profile cpu → http://ollama-cpu:11434
# For profile gpu → http://ollama-gpu:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_LLM_MODEL=qwen2.5:7b
OLLAMA_MODELS=qwen2.5:7b

# ── MCP ──────────────────────────────────────────────────────────────────────
MCP_SERVER_URL=http://osm-mcp:8080/sse

# ── OpenStreetMap upstreams (override for self-hosted Overpass/OSRM/Nominatim)
NOMINATIM_URL=https://nominatim.openstreetmap.org
OVERPASS_URL=https://overpass-api.de/api/interpreter
OSRM_URL=https://router.project-osrm.org

# Nominatim/Overpass usage policy requires a meaningful user-agent and
# a contact address for non-trivial traffic.
OSM_USER_AGENT=osm-mcp/0.1 (agent-engineering-studio)
OSM_CONTACT_EMAIL=

# ── ASP.NET ──────────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production

# ── Azure deployment (used by scripts/deploy-azure.*) ────────────────────────
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=rg-osm-mcp
AZURE_LOCATION=westeurope
AZURE_ACR_NAME=osmmcpacr
AZURE_CONTAINER_APP_ENV=cae-osm-mcp
AZURE_MCP_APP_NAME=osm-mcp
AZURE_AGENT_APP_NAME=osm-agent
IMAGE_TAG=latest
